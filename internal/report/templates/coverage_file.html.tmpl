{{define "coverage_file.html.tmpl"}}<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Path}} — Coverage</title>
{{template "styles"}}
</head>
<body>
<div class="wrap">
  <p class="crumbs"><a href="../index.html">← Report</a> / <a href="index.html">Coverage</a> / {{.Path}}</p>
  <header class="top"><h1 style="font-size:16px;font-family:ui-monospace,monospace">{{.Path}}</h1><span class="pill g-{{.LineGrade}}" style="font-size:18px">{{pct1 .Summary.Pct}}</span></header>
  <div class="sub">{{.Summary.Covered}}/{{.Summary.Total}} lines covered{{if gt .Branches.Total 0}} · branches {{.Branches.Covered}}/{{.Branches.Total}} ({{pct1 .Branches.Pct}}){{end}}</div>

  <section style="margin-top:18px">
    {{if .Lines}}
    <table class="src">
      <tbody>
      {{range .Lines}}
        <tr class="{{.Class}}">
          <td class="ln">{{.Number}}</td>
          <td class="hits">{{if ge .Hits 0}}{{.Hits}}×{{end}}</td>
          <td class="code">{{.Code}}</td>
        </tr>
      {{end}}
      </tbody>
    </table>
    {{else}}
    <div class="empty">No line data available for this file.</div>
    {{end}}
  </section>
  <footer>Generated by <a href="https://github.com/jhl-labs/test-cli">test-cli</a></footer>
</div>
</body>
</html>{{end}}
