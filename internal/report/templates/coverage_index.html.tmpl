{{define "coverage_index.html.tmpl"}}<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Coverage</title>
{{template "styles"}}
</head>
<body>
<div class="wrap">
  <p class="crumbs"><a href="../index.html">← Report</a> / Coverage</p>
  <header class="top"><h1>Coverage</h1><span class="pill g-{{.LineGrade}}" style="font-size:20px">{{pct1 .Summary.Lines.Pct}}</span></header>
  <div class="sub">test-cli {{.ToolVersion}} · generated {{.GeneratedAt}} · {{.Summary.Lines.Covered}}/{{.Summary.Lines.Total}} lines{{if gt .Summary.Branches.Total 0}} · branches {{pct1 .Summary.Branches.Pct}}{{end}}</div>

  <section>
    <h2>Files ({{len .Files}})</h2>
    <input class="filter" type="text" placeholder="Filter files…" onkeyup="filterRows(this.value)">
    <table id="files">
      <thead><tr><th>File</th><th style="width:40%">Coverage</th><th class="num">Lines</th></tr></thead>
      <tbody>
      {{range .Files}}
        <tr data-path="{{.Path}}">
          <td><a href="{{.Slug}}">{{.Path}}</a></td>
          <td>
            <div style="display:flex;align-items:center;gap:8px">
              <div class="bar" style="flex:1"><span class="g-{{.Grade}}" style="width:{{printf "%.0f" .PctNum}}%"></span></div>
              <span class="pill g-{{.Grade}}">{{.Pct}}</span>
            </div>
          </td>
          <td class="num">{{.Covered}}/{{.Total}}</td>
        </tr>
      {{end}}
      </tbody>
    </table>
  </section>
  <footer>Generated by <a href="https://github.com/jhl-labs/test-cli">test-cli</a></footer>
</div>
<script>
function filterRows(q) {
  q = q.toLowerCase();
  document.querySelectorAll('#files tbody tr').forEach(function (tr) {
    var p = (tr.getAttribute('data-path') || '').toLowerCase();
    tr.style.display = p.indexOf(q) >= 0 ? '' : 'none';
  });
}
</script>
</body>
</html>{{end}}
