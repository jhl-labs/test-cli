{{define "dashboard.html.tmpl"}}<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Test &amp; Coverage Report</title>
{{template "styles"}}
</head>
<body>
<div class="wrap">
  <header class="top">
    <h1>Test &amp; Coverage Report</h1>
    <span class="badge {{.StatusClass}}">{{.Status}}</span>
  </header>
  <div class="sub">test-cli {{.ToolVersion}} · generated {{.GeneratedAt}}{{if .Languages}} · {{range $i, $l := .Languages}}{{if $i}}, {{end}}{{$l}}{{end}}{{end}}</div>

  <div class="cards">
    <div class="card s-{{.StatusClass}}"><div class="k">Result</div><div class="v">{{.Status}}</div></div>
    <div class="card"><div class="k">Tests</div><div class="v">{{.Test.Total}}</div></div>
    <div class="card"><div class="k">Failed</div><div class="v">{{add .Test.Failed .Test.Errors}}</div></div>
    <div class="card"><div class="k">Skipped</div><div class="v">{{.Test.Skipped}}</div></div>
    <div class="card"><div class="k">Pass rate</div><div class="v">{{.PassRate}}</div></div>
    {{if .HasCoverage}}<div class="card"><div class="k">Line coverage</div><div class="v pill g-{{.LineGrade}}">{{pct1 .Coverage.Lines.Pct}}</div></div>{{end}}
  </div>

  {{if .LangRows}}
  <section>
    <h2>By language</h2>
    <table>
      <thead><tr><th>Language</th><th class="num">Tests</th><th class="num">Failed</th><th class="num">Skipped</th><th>Line coverage</th></tr></thead>
      <tbody>
      {{range .LangRows}}
        <tr>
          <td>{{.Name}}</td>
          <td class="num">{{.Tests}}</td>
          <td class="num">{{.Failed}}</td>
          <td class="num">{{.Skipped}}</td>
          <td><span class="pill g-{{.CovGrade}}">{{.CovPct}}</span></td>
        </tr>
      {{end}}
      </tbody>
    </table>
  </section>
  {{end}}

  <section>
    <h2>Failures{{if .Failures}} ({{len .Failures}}){{end}}</h2>
    {{if .Failures}}
      {{range .Failures}}
      <details class="fail">
        <summary><span class="tag">{{.Language}}</span><strong>{{.Suite}}</strong> › {{.Name}}{{if .Message}} — {{.Message}}{{end}}</summary>
        {{if .Detail}}<pre>{{.Detail}}</pre>{{end}}
      </details>
      {{end}}
    {{else}}
      <div class="empty">No failing tests. 🎉</div>
    {{end}}
  </section>

  {{if .HasCoverage}}
  <section>
    <h2>Lowest coverage files · <a href="coverage/index.html">full heatmap →</a></h2>
    <table>
      <thead><tr><th>File</th><th>Coverage</th><th class="num">Lines</th></tr></thead>
      <tbody>
      {{range .WorstFiles}}
        <tr>
          <td><a href="coverage/{{.Slug}}">{{.Path}}</a></td>
          <td>
            <div style="display:flex;align-items:center;gap:8px">
              <div class="bar"><span class="g-{{.Grade}}" style="width:{{printf "%.0f" .PctNum}}%"></span></div>
              <span class="pill g-{{.Grade}}">{{.Pct}}</span>
            </div>
          </td>
          <td class="num">{{.Covered}}/{{.Total}}</td>
        </tr>
      {{end}}
      </tbody>
    </table>
  </section>
  {{end}}

  <footer>Generated by <a href="https://github.com/jhl-labs/test-cli">test-cli</a> · schema test-cli/report@1</footer>
</div>
</body>
</html>{{end}}
