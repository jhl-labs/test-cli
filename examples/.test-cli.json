{
  "outputDir": "reports/test",
  "formats": ["stdout", "json", "junit", "cobertura", "markdown", "html"],
  "failUnder": 80,
  "languages": ["go", "python"],
  "commands": {
    "typescript": [
      ["npx", "--yes", "vitest", "run", "--coverage", "--coverage.reporter=cobertura", "--reporter=junit", "--outputFile={out}/junit.xml"]
    ],
    "java": [
      ["./gradlew", "test", "jacocoTestReport"]
    ]
  }
}
